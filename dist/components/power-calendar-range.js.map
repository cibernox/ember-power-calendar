import { precompileTemplate } from "@ember/template-compilation";
export default precompileTemplate("{{#let (assign this.publicAPI (hash\n  Nav=(component (ensure-safe-component (or @navComponent this.navComponent)) calendar=(readonly this.publicAPI))\n  Days=(component (ensure-safe-component (or @daysComponent this.daysComponent)) calendar=(readonly this.publicAPI))\n)) as |calendar|}}\n  {{#let (element this.tagWithDefault) as |Tag|}}\n    <Tag class=\"ember-power-calendar\" ...attributes id={{calendar.uniqueId}}>\n      {{#if (has-block)}}\n        {{yield calendar}}\n      {{else}}\n        <calendar.Nav/>\n        <calendar.Days/>\n      {{/if}}\n    </Tag>\n  {{/let}}\n{{/let}}\n")